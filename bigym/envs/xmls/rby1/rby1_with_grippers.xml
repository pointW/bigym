<?xml version="1.0"?>
<mujoco model="rby1_with_grippers">
  <compiler angle="radian" autolimits="true" eulerseq="xyz" />
  
  <option cone="elliptic" impratio="10"/>
  
  <default>
    <joint armature="10" damping="50" range="-3.14 3.14" />
    <material specular="0.5" shininess="0.25" />
    
    <default class="rby1">
      <default class="visual">
        <geom material="black" type="mesh" group="2" contype="0" conaffinity="0" />
      </default>
      <default class="collision">
        <geom material="red" group="3" />
      </default>
    </default>
  </default>

  <visual>
    <map force="0.1" zfar="30"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="4096"/>
    <global offwidth="800" offheight="800"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512" />
    <texture name="plane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" width="512" height="512"
      mark="cross" markrgb=".8 .8 .8" />
    <material name="plane" reflectance="0.3" texture="plane" texrepeat="1 1" texuniform="true" />
    <material name="black" rgba="0.1 0.1 0.1 1"/>
    <material name="red" rgba="0.8 0.2 0.2 0.4"/>
    
    <!-- Include RBY1 assets -->
    <include file="./assets/materials.xml" />
    <include file="./assets/base/assets.xml" />
    <include file="./assets/MECANUM_WHEEL/assets.xml" />
    <include file="./assets/MECANUM_WHEEL_M/assets.xml" />
    <include file="./assets/WHEEL/assets.xml" />
    <include file="./assets/EE_BODY/assets.xml" />
    <include file="./assets/EE_FINGER/assets.xml" />
    <include file="./assets/FT_SENSOR_L/assets.xml" />
    <include file="./assets/FT_SENSOR_R/assets.xml" />
    <include file="./assets/LINK_1/assets.xml" />
    <include file="./assets/LINK_2/assets.xml" />
    <include file="./assets/LINK_3/assets.xml" />
    <include file="./assets/LINK_4/assets.xml" />
    <include file="./assets/LINK_5/assets.xml" />
    <include file="./assets/LINK_6/assets.xml" />
    <include file="./assets/LINK_7/assets.xml" />
    <include file="./assets/LINK_8/assets.xml" />
    <include file="./assets/LINK_9/assets.xml" />
    <include file="./assets/LINK_10/assets.xml" />
    <include file="./assets/LINK_11/assets.xml" />
    <include file="./assets/LINK_12/assets.xml" />
    <include file="./assets/LINK_13/assets.xml" />
    <include file="./assets/LINK_14/assets.xml" />
    <include file="./assets/LINK_15/assets.xml" />
    <include file="./assets/LINK_16/assets.xml" />
    <include file="./assets/LINK_17/assets.xml" />
    <include file="./assets/LINK_18/assets.xml" />
    <include file="./assets/LINK_19/assets.xml" />
    <include file="./assets/LINK_20/assets.xml" />
    <include file="./assets/PAN_TILT_1/assets.xml" />
    <include file="./assets/PAN_TILT_2/assets.xml" />
    <include file="./assets/PAN_TILT_3/assets.xml" />
  </asset>

  <worldbody>
    <!-- Include the main RBY1 body structure from the base file -->
    <include file="./rby1.xml" />
  </worldbody>

  <actuator>
    <!-- Wheel actuators (velocity controlled) -->
    <velocity name="wheel_fr" joint="wheel_fr" ctrlrange="-3.14 3.14" ctrllimited="true" />
    <velocity name="wheel_fl" joint="wheel_fl" ctrlrange="-3.14 3.14" ctrllimited="true" />
    <velocity name="wheel_rr" joint="wheel_rr" ctrlrange="-3.14 3.14" ctrllimited="true" />
    <velocity name="wheel_rl" joint="wheel_rl" ctrlrange="-3.14 3.14" ctrllimited="true" />

    <!-- Torso actuators (position controlled) -->
    <position name="torso_0" joint="torso_0" ctrlrange="-0.349066 0.349066" ctrllimited="true" kp="4000" kv="400" />
    <position name="torso_1" joint="torso_1" ctrlrange="-1.0472 1.52173" ctrllimited="true" kp="4000" kv="400" />
    <position name="torso_2" joint="torso_2" ctrlrange="-2.47837 1.5708" ctrllimited="true" kp="4000" kv="400" />
    <position name="torso_3" joint="torso_3" ctrlrange="-0.785398 1.5708" ctrllimited="true" kp="4000" kv="400" />
    <position name="torso_4" joint="torso_4" ctrlrange="-0.523599 0.523599" ctrllimited="true" kp="4000" kv="400" />
    <position name="torso_5" joint="torso_5" ctrlrange="-1.5708 1.5708" ctrllimited="true" kp="4000" kv="400" />

    <!-- Right arm actuators (position controlled) -->
    <position name="right_arm_0" joint="right_arm_0" ctrlrange="-2.35619 2.35619" ctrllimited="true" kp="4000" kv="400" />
    <position name="right_arm_1" joint="right_arm_1" ctrlrange="-3.14159 0.05" ctrllimited="true" kp="4000" kv="400" />
    <position name="right_arm_2" joint="right_arm_2" ctrlrange="-2.0944 2.0944" ctrllimited="true" kp="4000" kv="400" />
    <position name="right_arm_3" joint="right_arm_3" ctrlrange="-2.61799 0.01" ctrllimited="true" kp="4000" kv="400" />
    <position name="right_arm_4" joint="right_arm_4" ctrlrange="-6.28319 6.28319" ctrllimited="true" kp="4000" kv="400" />
    <position name="right_arm_5" joint="right_arm_5" ctrlrange="-1.74533 2.00713" ctrllimited="true" kp="4000" kv="400" />
    <position name="right_arm_6" joint="right_arm_6" ctrlrange="-2.96706 2.96706" ctrllimited="true" kp="4000" kv="400" />

    <!-- Left arm actuators (position controlled) -->
    <position name="left_arm_0" joint="left_arm_0" ctrlrange="-2.35619 2.35619" ctrllimited="true" kp="4000" kv="400" />
    <position name="left_arm_1" joint="left_arm_1" ctrlrange="-0.05 3.14159" ctrllimited="true" kp="4000" kv="400" />
    <position name="left_arm_2" joint="left_arm_2" ctrlrange="-2.0944 2.0944" ctrllimited="true" kp="4000" kv="400" />
    <position name="left_arm_3" joint="left_arm_3" ctrlrange="-2.61799 0.01" ctrllimited="true" kp="4000" kv="400" />
    <position name="left_arm_4" joint="left_arm_4" ctrlrange="-6.28319 6.28319" ctrllimited="true" kp="4000" kv="400" />
    <position name="left_arm_5" joint="left_arm_5" ctrlrange="-1.74533 2.00713" ctrllimited="true" kp="4000" kv="400" />
    <position name="left_arm_6" joint="left_arm_6" ctrlrange="-2.96706 2.96706" ctrllimited="true" kp="4000" kv="400" />
  </actuator>
  
  <sensor>
    <!-- Add sensors as needed -->
  </sensor>
</mujoco>