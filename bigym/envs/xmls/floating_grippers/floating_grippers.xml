<mujoco model="floating_grippers">
  <compiler angle="radian" autolimits="true"/>
  
  <option gravity="0 0 -9.81" timestep="0.001"/>
  
  <default>
    <joint damping="0.1"/>
    <geom contype="1" conaffinity="1" friction="0.5 0.005 0.0001"/>
  </default>
  
  <worldbody>
    <!-- Dummy robot structure to satisfy Robot class requirements -->
    <!-- The actual floating grippers will be added via mocap bodies -->
    
    <!-- Central dummy body to serve as pelvis -->
    <body name="dummy_base" pos="0 0 0.5">
      <inertial pos="0 0 0" mass="1.0" diaginertia="0.01 0.01 0.01"/>
      <geom name="dummy_base_geom" type="sphere" size="0.05" rgba="0.5 0.5 0.5 0.3" contype="0" conaffinity="0"/>
      
      <!-- Dummy joints for the Robot class -->
      <body name="dummy_link1" pos="0.1 0 0">
        <joint name="dummy_joint1" type="hinge" axis="1 0 0" range="-0.1 0.1"/>
        <inertial pos="0 0 0" mass="0.1" diaginertia="0.001 0.001 0.001"/>
        <geom name="dummy_geom1" type="sphere" size="0.01" contype="0" conaffinity="0"/>
      </body>
      
      <body name="dummy_link2" pos="-0.1 0 0">
        <joint name="dummy_joint2" type="hinge" axis="1 0 0" range="-0.1 0.1"/>
        <inertial pos="0 0 0" mass="0.1" diaginertia="0.001 0.001 0.001"/>
        <geom name="dummy_geom2" type="sphere" size="0.01" contype="0" conaffinity="0"/>
      </body>
      
      <!-- Dummy sites required by Robot class config (not actually used) -->
      <!-- Making them very small and transparent -->
      <site name="left_gripper_site" pos="0 0 0" size="0.001" rgba="0 0 0 0"/>
      <site name="right_gripper_site" pos="0 0 0" size="0.001" rgba="0 0 0 0"/>
    </body>
  </worldbody>
  
  <actuator>
    <!-- Dummy actuators to satisfy Robot class -->
    <position name="dummy_actuator1" joint="dummy_joint1" kp="10"/>
    <position name="dummy_actuator2" joint="dummy_joint2" kp="10"/>
  </actuator>
</mujoco>